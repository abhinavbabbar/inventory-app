# ─────────────────────────────────────────────────────────────────────────────
# Production environment for the Docker Compose stack.
# Copy this to `.env` ON THE SERVER (never commit the real .env), then edit.
#   cp .env.production.example .env && nano .env
# Generate fresh secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ─────────────────────────────────────────────────────────────────────────────

# Your registered domain (apex). Its DNS A record must point at this server's IP.
DOMAIN=yourdomain.com

# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=you@example.com

# Postgres credentials (the DB runs inside the stack; not exposed to the internet).
POSTGRES_USER=inventory
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=inventory

# NextAuth session-signing secret. MUST be a fresh random 32+ byte value.
AUTH_SECRET=replace-with-openssl-rand-base64-32

# First-run admin account (created automatically on first boot).
# Change this password from the app after your first login.
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=replace-with-a-strong-password

# Set to "true" once if you want demo data on a brand-new database. Leave false for real use.
SEED_SAMPLE_DATA=false
