# Caddy automatically obtains and renews a Let's Encrypt TLS certificate
# for {$DOMAIN} as long as the domain's A record points at this server.
{$DOMAIN} {
	encode zstd gzip
	reverse_proxy app:3000
	tls {$ACME_EMAIL}
}

# Optional: also serve the www. host and redirect it to the apex.
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
	tls {$ACME_EMAIL}
}
