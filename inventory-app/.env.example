# Local development environment. Copy to `.env`:  cp .env.example .env

# Database — the app now uses PostgreSQL (matching production).
# Easiest local DB: run `docker compose up -d db` then expose port 5432, or use a
# free Neon branch. Example local URL:
DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Seed (optional overrides for `npm run db:seed`)
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe123!"
# SEED_SAMPLE_DATA="true"
