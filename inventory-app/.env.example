# Local development environment. Copy to `.env`:  cp .env.example .env

# Database — PostgreSQL (Neon in production).
# DATABASE_URL = pooled connection (used by the app at runtime).
# DIRECT_URL   = direct connection (used by Prisma migrations). For a plain local
#                Postgres they can be the same value; for Neon use the pooled vs
#                direct strings from the dashboard.
DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"
DIRECT_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Seed (optional overrides for `npm run db:seed`)
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe123!"
# SEED_SAMPLE_DATA="true"
